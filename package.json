{
  "name": "3we-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "dev": "npm run watch:css & wrangler pages dev public",
    "build": "node scripts/fetch-leaderboard.js && npm run build:css",
    "deploy": "npm run build && wrangler pages deploy public --project-name=3we-website"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "tailwindcss": "^3.4.19",
    "wrangler": "^4.14.0"
  }
}
